{
  "name": "discord",
  "version": "1.0.0",
  "description": "SCUM Discord server bot (economy, shop, tickets, stats)",
  "main": "src/bot.js",
  "scripts": {
    "setup:easy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-easy.ps1",
    "scum:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-audit.ps1",
    "scum:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-cleanup.ps1",
    "start": "node src/bot.js",
    "start:bot": "node src/bot.js",
    "start:worker": "node src/worker.js",
    "start:scum-agent": "node src/scum-console-agent.js",
    "scum:agent:exec": "node scripts/send-scum-agent-command.js",
    "start:watcher": "node scum-log-watcher.js",
    "start:web-standalone": "node apps/web-portal-standalone/server.js",
    "preview:spawn": "node scripts/preview-spawn-command.js",
    "cleanup:test-data": "node scripts/cleanup-test-data.js",
    "shop:canonicalize": "node scripts/canonicalize-shop-items.js",
    "doctor:topology": "node scripts/doctor-topology.js",
    "doctor:topology:prod": "node scripts/doctor-topology.js --production",
    "pm2:start:prod": "pm2 start deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:reload:prod": "pm2 reload deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:start:local": "pm2 start deploy/pm2.local.config.cjs --update-env",
    "pm2:start:scum-agent": "pm2 start deploy/pm2.scum-agent.config.cjs --update-env",
    "text:scan": "node scripts/repair-text.js",
    "text:repair": "node scripts/repair-text.js --write",
    "doctor:web-standalone": "node apps/web-portal-standalone/scripts/doctor.js",
    "doctor:web-standalone:prod": "node apps/web-portal-standalone/scripts/doctor.js --production",
    "register-commands": "node src/register-commands.js",
    "watch-scum": "node scum-log-watcher.js",
    "test": "node --test --test-concurrency=1",
    "lint": "node scripts/check-js-syntax.js && node scripts/check-text-encoding.js",
    "check": "npm run lint && npm test",
    "doctor": "node scripts/doctor.js",
    "readiness:full": "node scripts/readiness-gate.js",
    "readiness:prod": "node scripts/readiness-gate.js --production",
    "readiness:prod:audit": "node scripts/readiness-gate.js --production --with-audit",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.js",
    "security:check": "node scripts/security-check.js",
    "security:generate-secrets": "node scripts/generate-secrets.js",
    "security:rotate:prod:dry": "node scripts/rotate-production-secrets.js",
    "security:rotate:prod": "node scripts/rotate-production-secrets.js --write",
    "deploy:oneclick:win": "deploy\\one-click-production.cmd"
  },
  "keywords": [
    "discord",
    "bot",
    "scum",
    "game-server"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "rcon-client": "^4.2.5"
  },
  "overrides": {
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
