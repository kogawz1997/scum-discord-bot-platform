  @@index([status, updatedAt])
}

model ControlPlaneAgentSession {
  id             String   @id
  tenantId       String
  serverId       String
  guildId        String?
  agentId        String
  runtimeKey     String
  displayName    String?
  role           String   @default("hybrid")
  scope          String   @default("sync_execute")
