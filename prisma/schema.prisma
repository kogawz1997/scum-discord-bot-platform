  actor      String?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([tenantId, serverId, agentId, updatedAt])
  @@index([status, updatedAt])
}

