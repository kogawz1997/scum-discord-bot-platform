# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_guild_id_here

# SCUM Webhook Server (bot side)
SCUM_WEBHOOK_PORT=3100
SCUM_WEBHOOK_SECRET=put_a_strong_random_secret_here
SCUM_WEBHOOK_MAX_BODY_BYTES=65536
SCUM_WEBHOOK_REQUEST_TIMEOUT_MS=10000

# SCUM Log Watcher (tail SCUM.log and send to webhook)
# Windows path must escape backslash, e.g. D:\\SCUMServer\\SCUM.log
SCUM_LOG_PATH=D:\\SCUMServer\\SCUM.log
# If watcher runs on same machine as bot, usually no change needed
SCUM_WEBHOOK_URL=http://127.0.0.1:3100/scum-event

# Watcher tuning (optional)
SCUM_WATCH_INTERVAL_MS=800
SCUM_WEBHOOK_TIMEOUT_MS=7000
SCUM_WEBHOOK_MAX_RETRIES=2
SCUM_WEBHOOK_RETRY_DELAY_MS=900
SCUM_EVENT_DEDUP_WINDOW_MS=2000
SCUM_EVENT_DEDUPE_TRACK_SIZE=5000
SCUM_EVENT_QUEUE_MAX=2000
SCUM_DEAD_LETTER_LOG_PATH=logs/scum-watcher-dead-letter.log
SCUM_WEBHOOK_ERROR_ALERT_WINDOW_MS=300000
SCUM_WEBHOOK_ERROR_ALERT_MIN_ATTEMPTS=10
SCUM_WEBHOOK_ERROR_ALERT_THRESHOLD=0.3
SCUM_QUEUE_ALERT_THRESHOLD=1500
SCUM_ALERT_COOLDOWN_MS=60000

# Item icon index (shop/purchase displays)
SCUM_ITEMS_INDEX_PATH=./scum_items-main/index.json
SCUM_ITEMS_DIR_PATH=./scum_items-main
SCUM_ITEMS_BASE_URL=https://vbothost.github.io/scum_items/
# If true, ignore "url" field in index.json and build icon URL from filename in SCUM_ITEMS_BASE_URL.
# Recommended true when serving icons from local files/routes:
# - Admin web: /assets/scum-items/<filename>
# - Player portal standalone: /assets/scum-items/<filename>
SCUM_ITEMS_IGNORE_INDEX_URL=true
# Item category/source manifest (all categories + spawn format)
SCUM_ITEM_MANIFEST_PATH=./scum_item_category_manifest.json

# Admin Web Dashboard
# Login:
# - runtime checks users from DB table: admin_web_users
# - first startup will bootstrap users from:
#   1) ADMIN_WEB_USERS_JSON (if provided), or
#   2) ADMIN_WEB_USER + ADMIN_WEB_PASSWORD
# - if ADMIN_WEB_PASSWORD is empty, password falls back to ADMIN_WEB_TOKEN
# - if both are empty, system generates temporary token/password at startup
ADMIN_WEB_HOST=127.0.0.1
ADMIN_WEB_PORT=3200
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=
ADMIN_WEB_LOCAL_RECOVERY=false
# Optional JSON bootstrap (first startup / table empty use case):
# ADMIN_WEB_USERS_JSON=[{"username":"owner","password":"StrongPass123!","role":"owner"},{"username":"mod1","password":"StrongPass456!","role":"mod"}]
ADMIN_WEB_SESSION_TTL_HOURS=12
ADMIN_WEB_SESSION_COOKIE_NAME=scum_admin_session
ADMIN_WEB_SESSION_COOKIE_PATH=/
ADMIN_WEB_SESSION_COOKIE_SAMESITE=Strict
ADMIN_WEB_SESSION_COOKIE_DOMAIN=
ADMIN_WEB_SECURE_COOKIE=false
ADMIN_WEB_HSTS_ENABLED=false
ADMIN_WEB_HSTS_MAX_AGE_SEC=31536000
ADMIN_WEB_TOKEN=
ADMIN_WEB_MAX_BODY_BYTES=1048576
ADMIN_WEB_TRUST_PROXY=false
ADMIN_WEB_ALLOW_TOKEN_QUERY=false
ADMIN_WEB_ENFORCE_ORIGIN_CHECK=true
# Multiple origins via comma, e.g. http://127.0.0.1:3200,https://genz.noah-dns.online
ADMIN_WEB_ALLOWED_ORIGINS=
ADMIN_WEB_LOGIN_WINDOW_MS=60000
ADMIN_WEB_LOGIN_MAX_ATTEMPTS=8
ADMIN_WEB_LOGIN_SPIKE_WINDOW_MS=300000
ADMIN_WEB_LOGIN_SPIKE_THRESHOLD=10
ADMIN_WEB_LOGIN_SPIKE_IP_THRESHOLD=5
ADMIN_WEB_LOGIN_SPIKE_ALERT_COOLDOWN_MS=60000
ADMIN_WEB_2FA_ENABLED=false
ADMIN_WEB_2FA_SECRET=
ADMIN_WEB_2FA_WINDOW_STEPS=1
ADMIN_WEB_STEP_UP_ENABLED=false
ADMIN_WEB_STEP_UP_TTL_MINUTES=15
# Cache window for aggregated dashboard cards (ms)
ADMIN_DASHBOARD_CARDS_CACHE_WINDOW_MS=15000
# Optional admin Discord SSO
ADMIN_WEB_SSO_DISCORD_ENABLED=false
ADMIN_WEB_SSO_DISCORD_CLIENT_ID=
ADMIN_WEB_SSO_DISCORD_CLIENT_SECRET=
# e.g. https://genz.noah-dns.online/admin/auth/discord/callback
ADMIN_WEB_SSO_DISCORD_REDIRECT_URI=
ADMIN_WEB_SSO_DISCORD_GUILD_ID=
ADMIN_WEB_SSO_DEFAULT_ROLE=mod
ADMIN_WEB_SSO_DISCORD_OWNER_ROLE_IDS=
ADMIN_WEB_SSO_DISCORD_ADMIN_ROLE_IDS=
ADMIN_WEB_SSO_DISCORD_MOD_ROLE_IDS=
ADMIN_WEB_SSO_DISCORD_OWNER_ROLE_NAMES=
ADMIN_WEB_SSO_DISCORD_ADMIN_ROLE_NAMES=
ADMIN_WEB_SSO_DISCORD_MOD_ROLE_NAMES=
ADMIN_WEB_SSO_STATE_TTL_MS=600000

# Optional: persistent data directory override.
# Default:
# - development/local without DB-only mode -> ./data
# - production or PERSIST_REQUIRE_DB=true -> OS-managed state dir
#   Windows: %LOCALAPPDATA%\\SCUMTHPlatform\\data
#   Linux/macOS: ${XDG_STATE_HOME:-~/.local/state}/scum-th-platform/data
#BOT_DATA_DIR=Z:\\scum-bot-data

# Database
DATABASE_URL="file:./prisma/dev.db"
TENANT_DB_ISOLATION_MODE=postgres-rls-strict
TENANT_DB_TOPOLOGY_MODE=shared
TENANT_DB_SCHEMA_PREFIX=tenant_
TENANT_DB_DATABASE_PREFIX=tenant_
TENANT_DB_ADMIN_DATABASE=postgres
# Enforce DB-only persistence (recommended true in production after P2 migration)
PERSIST_REQUIRE_DB=false

# Public portal and billing
WEB_PORTAL_BASE_URL=http://127.0.0.1:3300
PLATFORM_PUBLIC_BASE_URL=http://127.0.0.1:3300
PLATFORM_BILLING_PROVIDER=platform_local
PLATFORM_BILLING_WEBHOOK_SECRET=put_a_strong_billing_webhook_secret_here
PLATFORM_BILLING_STRIPE_PUBLISHABLE_KEY=
PLATFORM_BILLING_STRIPE_SECRET_KEY=
# Optional legacy JSON snapshots for migration/backup only.
# Default: false when PERSIST_REQUIRE_DB=true or NODE_ENV=production, otherwise true.
PERSIST_LEGACY_SNAPSHOTS=true
# Production baseline:
# - NODE_ENV=production
# - PERSIST_REQUIRE_DB=true
# - PERSIST_LEGACY_SNAPSHOTS=false
ADMIN_NOTIFICATION_STORE_MODE=db
ADMIN_SECURITY_EVENT_STORE_MODE=db
PLATFORM_AUTOMATION_STATE_STORE_MODE=db
PLATFORM_OPS_STATE_STORE_MODE=db
CONTROL_PLANE_REGISTRY_STORE_MODE=db
CONTROL_PLANE_REGISTRY_FILE_MIRROR_SLICES=none

# Auto delivery via RCON queue
DELIVERY_EXECUTION_MODE=rcon
RCON_HOST=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=
# source | battleye
RCON_PROTOCOL=source
# Example:
# RCON_EXEC_TEMPLATE=mcrcon -H {host} -P {port} -p "{password}" "{command}"
RCON_EXEC_TEMPLATE=node scripts/rcon-send.js --host {host} --port {port} --password "{password}" --command "{command}"
#
# Optional console agent mode for delivery:
# - worker -> HTTP agent -> shell bridge OR managed SCUM process stdin
# - set DELIVERY_EXECUTION_MODE=agent to enable
SCUM_CONSOLE_AGENT_BASE_URL=http://127.0.0.1:3213
SCUM_CONSOLE_AGENT_HOST=127.0.0.1
SCUM_CONSOLE_AGENT_PORT=3213
SCUM_CONSOLE_AGENT_TOKEN=put_a_strong_agent_token_here
# exec | process
SCUM_CONSOLE_AGENT_BACKEND=exec
SCUM_CONSOLE_AGENT_COMMAND_TIMEOUT_MS=15000
SCUM_CONSOLE_AGENT_ALLOW_NON_HASH=false
# Optional agent workflow hooks (teleport -> spawn -> return)
# JSON array format:
# DELIVERY_AGENT_PRE_COMMANDS_JSON=["#TeleportTo {teleportTargetQuoted}"]
# DELIVERY_AGENT_POST_COMMANDS_JSON=["#TeleportTo {returnTargetQuoted}"]
DELIVERY_AGENT_PRE_COMMANDS_JSON=[]
DELIVERY_AGENT_POST_COMMANDS_JSON=[]
DELIVERY_AGENT_COMMAND_DELAY_MS=600
DELIVERY_AGENT_POST_TELEPORT_DELAY_MS=2000
DELIVERY_MAGAZINE_STACKCOUNT=100
DELIVERY_AGENT_TELEPORT_MODE=player
DELIVERY_AGENT_TELEPORT_TARGET=
DELIVERY_AGENT_RETURN_TARGET=
# For backend=exec
# Example: python C:\\scum-agent\\console_bridge.py --command "{command}"
# Example (admin client parked in SCUM on Windows):
# SCUM_CONSOLE_AGENT_EXEC_TEMPLATE=powershell -NoProfile -ExecutionPolicy Bypass -File scripts/send-scum-admin-command.ps1 -WindowTitle "SCUM" -SwitchToAdminChannel -AdminChannelTabs 3 -Command "{command}"
SCUM_CONSOLE_AGENT_EXEC_TEMPLATE=
# For backend=process (experimental; only works if SCUM build accepts stdin/console commands)
SCUM_CONSOLE_AGENT_AUTOSTART=false
SCUM_CONSOLE_AGENT_SERVER_EXE=
SCUM_CONSOLE_AGENT_SERVER_ARGS_JSON=[]
SCUM_CONSOLE_AGENT_SERVER_WORKDIR=
SCUM_CONSOLE_AGENT_PROCESS_RESPONSE_WAIT_MS=200
DELIVERY_METRICS_WINDOW_MS=300000
DELIVERY_FAIL_RATE_ALERT_THRESHOLD=0.3
DELIVERY_FAIL_RATE_ALERT_MIN_SAMPLES=10
DELIVERY_QUEUE_ALERT_THRESHOLD=25
DELIVERY_ALERT_COOLDOWN_MS=60000
DELIVERY_QUEUE_STUCK_SLA_MS=120000
DELIVERY_IDEMPOTENCY_SUCCESS_WINDOW_MS=43200000
DELIVERY_VERIFY_MODE=basic
DELIVERY_VERIFY_SUCCESS_REGEX=
DELIVERY_VERIFY_FAILURE_REGEX=
DELIVERY_VERIFY_OBSERVER_WINDOW_MS=60000
DELIVERY_NATIVE_PROOF_MODE=optional
DELIVERY_NATIVE_PROOF_SCRIPT=
DELIVERY_NATIVE_PROOF_TIMEOUT_MS=15000
DELIVERY_NATIVE_PROOF_WAIT_FOR_STATE_MS=15000
DELIVERY_NATIVE_PROOF_POLL_INTERVAL_MS=1500
PREFLIGHT_DELIVERY_TEST_ENABLED=false
PREFLIGHT_DELIVERY_TEST_ITEM_ID=
PREFLIGHT_DELIVERY_TEST_GAME_ITEM_ID=Weapon_M1911
PREFLIGHT_DELIVERY_TEST_QUANTITY=1
PREFLIGHT_DELIVERY_TEST_USER_ID=
PREFLIGHT_DELIVERY_TEST_STEAM_ID=

# Production startup guard:
# - If NODE_ENV=production, bot refuses to start when security baseline is weak.
# - Generate fresh secrets quickly:
#   npm run security:generate-secrets

# Runtime split flags (Phase 3: bot/web/worker separation)
# Bot process toggles:
# - Keep true for legacy single-process mode.
# - Set admin/rentbike/delivery=false when running dedicated worker + standalone web.
BOT_ENABLE_SCUM_WEBHOOK=true
BOT_ENABLE_RESTART_SCHEDULER=true
BOT_ENABLE_ADMIN_WEB=true
BOT_ENABLE_RENTBIKE_SERVICE=true
BOT_ENABLE_DELIVERY_WORKER=true
BOT_ENABLE_OPS_ALERT_ROUTE=true
BOT_HEALTH_HOST=127.0.0.1
BOT_HEALTH_PORT=0

# Dedicated worker toggles (used by `npm run start:worker`)
WORKER_ENABLE_RENTBIKE=true
WORKER_ENABLE_DELIVERY=true
WORKER_HEARTBEAT_MS=60000
WORKER_HEALTH_HOST=127.0.0.1
WORKER_HEALTH_PORT=0

# Optional watcher health endpoint
SCUM_WATCHER_HEALTH_HOST=127.0.0.1
SCUM_WATCHER_HEALTH_PORT=0
