# Standalone Web Portal (Player-only production template)
NODE_ENV=production
WEB_PORTAL_MODE=player
WEB_PORTAL_HOST=0.0.0.0
WEB_PORTAL_PORT=3300
WEB_PORTAL_BASE_URL=https://genz.noah-dns.online
WEB_PORTAL_LEGACY_ADMIN_URL=https://genz.noah-dns.online/admin

WEB_PORTAL_SESSION_TTL_HOURS=12
WEB_PORTAL_SECURE_COOKIE=true
WEB_PORTAL_COOKIE_SAMESITE=Lax
WEB_PORTAL_ENFORCE_ORIGIN_CHECK=true

WEB_PORTAL_DISCORD_CLIENT_ID=
# Leave blank here if you want to reuse ADMIN_WEB_SSO_DISCORD_CLIENT_SECRET
# from root .env. If you set a value here, this file takes priority.
WEB_PORTAL_DISCORD_CLIENT_SECRET=
WEB_PORTAL_DISCORD_REDIRECT_PATH=/auth/discord/callback

WEB_PORTAL_PLAYER_OPEN_ACCESS=true
WEB_PORTAL_DISCORD_GUILD_ID=
WEB_PORTAL_REQUIRE_GUILD_MEMBER=false
WEB_PORTAL_ALLOWED_DISCORD_IDS=

# Item icon source (serve from your own domain/static route in production)
SCUM_ITEMS_INDEX_PATH=./scum_items-main/index.json
SCUM_ITEMS_DIR_PATH=./scum_items-main
# Example:
# SCUM_ITEMS_BASE_URL=https://portal.example.com/assets/scum-items/
SCUM_ITEMS_BASE_URL=
SCUM_ITEMS_IGNORE_INDEX_URL=true

WEB_PORTAL_OAUTH_STATE_TTL_MS=600000
WEB_PORTAL_CLEANUP_INTERVAL_MS=60000

WEB_PORTAL_MAP_EMBED_ENABLED=true
WEB_PORTAL_MAP_EXTERNAL_URL=https://scum-map.com/th/map/bunkers_and_killboxes
WEB_PORTAL_MAP_EMBED_URL=https://scum-map.com/th/map/bunkers_and_killboxes
