model ControlPlaneSyncRun {
  id           String   @id
  tenantId     String
  serverId     String
  guildId      String?
  agentId      String
  runtimeKey   String
  role         String   @default("hybrid")
  scope        String   @default("sync_execute")
  sourceType   String   @default("log")
  sourcePath   String?
  version      String?
  freshnessAt  DateTime @default(now())
  eventCount   Int      @default(0)
  errorsJson   String?
  snapshotJson String?
  actor        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([tenantId, serverId, agentId, updatedAt])
  @@index([freshnessAt])
}

model ControlPlaneSyncEvent {
  id          String   @id
  syncRunId   String
  tenantId    String
  serverId    String
  guildId     String?
  agentId     String
  runtimeKey  String
  type        String   @default("event")
  summary     String?
  payloadJson String?
  createdAt   DateTime @default(now())

  @@index([syncRunId, createdAt])
  @@index([tenantId, serverId, agentId, createdAt])
}

model PlatformPackageCatalogEntry {
  id          String   @id
  title       String
  description String?
  status      String   @default("active")
  featuresJson String
  position    Int      @default(0)
  isSystem    Boolean  @default(false)
  metadataJson String?
  actor       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([status, position, updatedAt])
}
