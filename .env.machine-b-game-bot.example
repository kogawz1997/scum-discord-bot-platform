# Machine B: game bot execution node
# Use on the Windows host that owns:
# - SCUM client
# - console-agent
# - watcher (if SCUM.log lives here)
#
# Keep business state on Machine A. This node executes commands and forwards
# watcher events back to Machine A.

NODE_ENV=production
DATABASE_PROVIDER=postgresql
PRISMA_SCHEMA_PROVIDER=postgresql
DATABASE_URL="postgresql://app:change-me@control-plane-db.example.internal:5432/scum_th_platform?schema=public"
PERSIST_REQUIRE_DB=true
PERSIST_LEGACY_SNAPSHOTS=false
ADMIN_SECURITY_EVENT_STORE_MODE=db
PLATFORM_AUTOMATION_STATE_STORE_MODE=db
PLATFORM_OPS_STATE_STORE_MODE=db
CONTROL_PLANE_REGISTRY_STORE_MODE=db
CONTROL_PLANE_REGISTRY_FILE_MIRROR_SLICES=none
TENANT_DB_ISOLATION_MODE=postgres-rls-strict
TENANT_DB_TOPOLOGY_MODE=schema-per-tenant

ADMIN_WEB_SESSION_COOKIE_PATH=/
ADMIN_WEB_SESSION_COOKIE_DOMAIN=admin.example.com
ADMIN_WEB_SECURE_COOKIE=true
ADMIN_WEB_ALLOWED_ORIGINS=https://admin.example.com

DELIVERY_EXECUTION_MODE=agent
SCUM_CONSOLE_AGENT_BASE_URL=http://127.0.0.1:3213
SCUM_CONSOLE_AGENT_HOST=0.0.0.0
SCUM_CONSOLE_AGENT_PORT=3213
SCUM_CONSOLE_AGENT_TOKEN=put_a_strong_agent_token_here
SCUM_CONSOLE_AGENT_BACKEND=exec
SCUM_CONSOLE_AGENT_EXEC_TEMPLATE="powershell -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\send-scum-admin-command.ps1 -Command \"{command}\""

PLATFORM_API_BASE_URL=https://control-plane.example.com
SCUM_SYNC_CONTROL_PLANE_URL=https://control-plane.example.com
PLATFORM_AGENT_SETUP_TOKEN=replace_with_one_time_setup_token
PLATFORM_AGENT_TOKEN=
SCUM_TENANT_ID=tenant-example
PLATFORM_TENANT_ID=tenant-example
SCUM_SERVER_ID=server-example
PLATFORM_SERVER_ID=server-example
SCUM_SERVER_BOT_AGENT_ID=server-bot-main
SCUM_SERVER_BOT_RUNTIME_KEY=server-bot-main
SCUM_SERVER_CONFIG_ROOT=D:\\SCUMServer\\Config
SCUM_SERVER_APPLY_TEMPLATE="powershell -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\apply-scum-config.ps1 -ConfigRoot \"{configRoot}\""
SCUM_SERVER_RESTART_TEMPLATE="powershell -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\restart-scum-server.ps1"
SCUM_SERVER_START_TEMPLATE="powershell -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\start-scum-server.ps1"
SCUM_SERVER_STOP_TEMPLATE="powershell -NoProfile -ExecutionPolicy Bypass -File C:\\path\\to\\stop-scum-server.ps1"
SCUM_SERVER_BOT_HEALTH_HOST=127.0.0.1
SCUM_SERVER_BOT_HEALTH_PORT=3214

SCUM_WATCHER_ENABLED=true
SCUM_WATCHER_HEALTH_HOST=127.0.0.1
SCUM_WATCHER_HEALTH_PORT=3212
SCUM_WEBHOOK_URL=https://control-plane.example.com/scum-event
SCUM_LOG_PATH=D:\\SCUMServer\\SCUM.log

BOT_ENABLE_SCUM_WEBHOOK=false
BOT_ENABLE_ADMIN_WEB=false
BOT_ENABLE_RENTBIKE_SERVICE=false
BOT_ENABLE_DELIVERY_WORKER=false
BOT_HEALTH_PORT=0

WORKER_ENABLE_RENTBIKE=false
WORKER_ENABLE_DELIVERY=false
WORKER_HEALTH_PORT=0
