{
  "name": "scum-th-platform",
  "version": "1.0.0",
  "description": "SCUM TH control plane with Discord bot, admin web, player portal, worker, watcher, and optional console-agent",
  "main": "src/bot.js",
  "scripts": {
    "setup:easy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-easy.ps1",
    "scum:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-audit.ps1",
    "scum:cleanup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scum-instance-cleanup.ps1",
    "start": "node src/bot.js",
    "start:bot": "node src/bot.js",
    "start:worker": "node src/worker.js",
    "start:scum-agent": "node src/scum-console-agent.js",
    "scum:agent:exec": "node scripts/send-scum-agent-command.js",
    "start:watcher": "node src/services/scumLogWatcherRuntime.js",
    "start:web-standalone": "node apps/web-portal-standalone/server.js",
    "preview:spawn": "node scripts/preview-spawn-command.js",
    "cleanup:test-data": "node scripts/cleanup-test-data.js",
    "repair:vip-purchases": "node scripts/repair-vip-purchases.js",
    "db:text:scan": "node scripts/repair-database-text.js",
    "db:text:repair": "node scripts/repair-database-text.js --write",
    "shop:canonicalize": "node scripts/canonicalize-shop-items.js",
    "doctor:topology": "node scripts/doctor-topology.js",
    "doctor:topology:prod": "node scripts/doctor-topology.js --production",
    "pm2:start:prod": "pm2 start deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:reload:prod": "pm2 reload deploy/pm2.ecosystem.config.cjs --update-env",
    "pm2:start:local": "pm2 start deploy/pm2.local.config.cjs --update-env",
    "pm2:start:scum-agent": "pm2 start deploy/pm2.scum-agent.config.cjs --update-env",
    "text:scan": "node scripts/repair-text.js",
    "text:repair": "node scripts/repair-text.js --write",
    "doctor:web-standalone": "node apps/web-portal-standalone/scripts/doctor.js",
    "doctor:web-standalone:prod": "node apps/web-portal-standalone/scripts/doctor.js --production",
    "register-commands": "node src/register-commands.js",
    "watch-scum": "node src/services/scumLogWatcherRuntime.js",
    "test": "node scripts/run-tests-with-provider.js",
    "test:policy": "node --test test/runtime-profile.test.js test/admin-editable-config.test.js test/check-module-docs.test.js test/post-deploy-smoke.test.js test/readiness-gate.test.js test/portal-runtime.test.js test/portal-auth-runtime.test.js test/portal-request-runtime.test.js test/portal-page-asset-runtime.test.js test/portal-server-lifecycle.test.js test/admin-page-runtime.test.js test/admin-tenant-scope.test.js test/tenant-db-isolation.test.js test/tenant-database-topology.test.js test/prisma-tenant-topology.test.js test/run-tests-with-provider.test.js test/build-native-proof-coverage-report.test.js",
    "lint:syntax": "node scripts/check-js-syntax.js",
    "lint:text": "node scripts/check-text-encoding.js",
    "lint:eslint": "eslint .",
    "check:jsdoc": "node scripts/check-module-docs.js",
    "check:release-notes": "node scripts/check-release-notes.js",
    "format:check": "prettier --check \"*.{json,md,yml,yaml}\" \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\"",
    "format:write": "prettier --write \"*.{json,md,yml,yaml}\" \".github/**/*.{md,yml,yaml}\" \"docs/**/*.md\"",
    "lint": "npm run lint:syntax && npm run lint:text && npm run lint:eslint && npm run check:jsdoc && npm run check:release-notes && npm run format:check",
    "check": "npm run lint && npm test",
    "ci:verify": "node scripts/run-ci-verification.js",
    "doctor": "node scripts/doctor.js",
    "readiness:full": "node scripts/readiness-gate.js",
    "readiness:prod": "node scripts/readiness-gate.js --production",
    "readiness:prod:audit": "node scripts/readiness-gate.js --production --with-audit",
    "preflight:prod": "node scripts/preflight-prod.js",
    "smoke:postdeploy": "node scripts/post-deploy-smoke.js",
    "smoke:local-ci": "node scripts/run-local-smoke-stack.js",
    "docs:capture-evidence": "node scripts/capture-doc-evidence.js",
    "docs:build-native-proof-coverage": "node scripts/build-native-proof-coverage-report.js",
    "docs:build-demo-gif": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-doc-demo-gif.ps1",
    "admin:sso:roles": "node scripts/export-admin-discord-roles.js",
    "security:check": "node scripts/security-check.js",
    "secret:scan": "node scripts/secret-scan.js",
    "security:scan-secrets": "node scripts/secret-scan.js",
    "security:scan-secrets:staged": "node scripts/secret-scan.js --staged",
    "security:generate-secrets": "node scripts/generate-secrets.js",
    "security:generate-admin-2fa": "node scripts/generate-admin-2fa-secret.js",
    "security:scaffold-split-env": "node scripts/scaffold-split-origin-env.js",
    "security:apply-split-env": "node scripts/apply-split-origin-env.js",
    "security:activate-split-env": "node scripts/activate-split-origin-env.js",
    "security:rotate:prod:dry": "node scripts/rotate-production-secrets.js",
    "security:rotate:prod": "node scripts/rotate-production-secrets.js --write",
    "env:preview:development": "node scripts/setup-env-profile.js --profile=development",
    "env:preview:test": "node scripts/setup-env-profile.js --profile=test",
    "env:preview:production": "node scripts/setup-env-profile.js --profile=production",
    "env:prepare:development": "node scripts/setup-env-profile.js --profile=development --write",
    "env:prepare:test": "node scripts/setup-env-profile.js --profile=test --write",
    "env:prepare:production": "node scripts/setup-env-profile.js --profile=production --write",
    "db:generate": "node scripts/prisma-with-provider.js generate",
    "db:generate:sqlite": "node scripts/prisma-with-provider.js --provider sqlite generate",
    "db:generate:postgresql": "node scripts/prisma-with-provider.js --provider postgresql generate",
    "db:generate:mysql": "node scripts/prisma-with-provider.js --provider mysql generate",
    "db:push": "node scripts/prisma-with-provider.js db push --skip-generate",
    "db:push:sqlite": "node scripts/prisma-with-provider.js --provider sqlite db push --skip-generate",
    "db:push:postgresql": "node scripts/prisma-with-provider.js --provider postgresql db push --skip-generate",
    "db:push:mysql": "node scripts/prisma-with-provider.js --provider mysql db push --skip-generate",
    "db:tenant-isolation:status": "node scripts/postgres-tenant-rls.js --action status --json",
    "db:tenant-isolation:install": "node scripts/postgres-tenant-rls.js --action install --json",
    "db:tenant-isolation:disable": "node scripts/postgres-tenant-rls.js --action disable --json",
    "db:tenant-topology:preview": "node scripts/tenant-database-topology.js --action preview --json",
    "db:tenant-topology:provision:schema": "node scripts/tenant-database-topology.js --action provision-schema --json",
    "db:tenant-topology:provision:database": "node scripts/tenant-database-topology.js --action provision-database --json",
    "db:tenant-topology:cutover:schema": "node scripts/cutover-shared-to-tenant-schema.js --json",
    "db:migrate:status": "node scripts/prisma-with-provider.js migrate status",
    "db:migrate:deploy": "node scripts/prisma-with-provider.js migrate deploy",
    "db:migrate:deploy:sqlite": "node scripts/prisma-with-provider.js --provider sqlite migrate deploy",
    "db:migrate:deploy:postgresql": "node scripts/prisma-with-provider.js --provider postgresql migrate deploy",
    "db:migrate:deploy:mysql": "node scripts/prisma-with-provider.js --provider mysql migrate deploy",
    "db:migrate:deploy:safe": "node scripts/migrate-with-rollback.js",
    "hooks:install": "node scripts/install-git-hooks.js",
    "deploy:oneclick:win": "deploy\\one-click-production.cmd",
    "platform:schema:upgrade": "node scripts/platform-schema-upgrade.js",
    "platform:bootstrap:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/platform-bootstrap.ps1",
    "postgres:local:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-local.ps1 -Action init",
    "postgres:local:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-local.ps1 -Action start",
    "postgres:local:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-local.ps1 -Action stop",
    "postgres:local:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-local.ps1 -Action status",
    "postgres:local:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/postgres-local.ps1 -Action setup",
    "db:cutover:postgresql": "node scripts/cutover-sqlite-to-postgres.js"
  },
  "keywords": [
    "discord",
    "bot",
    "scum",
    "game-server",
    "control-plane",
    "admin-web",
    "player-portal"
  ],
  "author": "Taweporn Chok (kogawz1997) <tawepornchok@gmail.com>",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kogawz1997/Scum-bot-discord-Full-.git"
  },
  "bugs": {
    "url": "https://github.com/kogawz1997/Scum-bot-discord-Full-/issues"
  },
  "homepage": "https://github.com/kogawz1997/Scum-bot-discord-Full-#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "rcon-client": "^4.2.5"
  },
  "overrides": {
    "undici": "^6.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "prisma": "^5.22.0"
  }
}
