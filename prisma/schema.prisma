// Source-of-truth note:
// This checked-in schema stays on sqlite as the repository compatibility template.
// Provider-specific schemas for postgresql/mysql are rendered by scripts/prisma-with-provider.js.
// Production/runtime provider truth comes from DATABASE_URL + PRISMA_SCHEMA_PROVIDER/DATABASE_PROVIDER
// plus the rendered Prisma schema/client, not from this source file alone.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserWallet {
  userId      String         @id
  balance     Int            @default(0)
  lastDaily   BigInt? // ms since epoch
  lastWeekly  BigInt? // ms since epoch
  ledgers     WalletLedger[]
}

model ShopItem {
  id                      String @id
  name                    String
  price                   Int
  description             String
  kind                    String @default("item")
  gameItemId              String?
  quantity                Int    @default(1)
  iconUrl                 String?
  deliveryItemsJson       String?
  deliveryProfile         String?
  deliveryTeleportMode    String?
  deliveryTeleportTarget  String?
  deliveryPreCommandsJson String?
  deliveryPostCommandsJson String?
  deliveryReturnTarget    String?
}

model Purchase {
  id              Int                     @id @default(autoincrement())
  code            String                  @unique
  tenantId        String?
  userId          String
  itemId          String
  price           Int
  status          String                  @default("pending")
  statusUpdatedAt DateTime                @default(now())
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @default(now()) @updatedAt
  statusHistory   PurchaseStatusHistory[]

  @@index([tenantId, createdAt])
}

model CartEntry {
  userId    String
  itemId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@id([userId, itemId])
  @@index([userId, updatedAt])
  @@index([updatedAt])
}

model WalletLedger {
  id            Int       @id @default(autoincrement())
  userId        String
  delta         Int
  balanceBefore Int
  balanceAfter  Int
  reason        String
  reference     String?
  actor         String?
  metaJson      String?
  createdAt     DateTime  @default(now())
  wallet        UserWallet @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reason, createdAt])
}

model PurchaseStatusHistory {
  id           Int      @id @default(autoincrement())
  purchaseCode String
  fromStatus   String?
  toStatus     String
  reason       String?
  actor        String?
  metaJson     String?
  createdAt    DateTime @default(now())
  purchase     Purchase @relation(fields: [purchaseCode], references: [code], onDelete: Cascade)

  @@index([purchaseCode, createdAt])
  @@index([toStatus, createdAt])
}

model PlayerAccount {
  discordId   String   @id
  username    String?
  displayName String?
  avatarUrl   String?
  steamId     String?  @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model GuildEvent {
  id           Int                    @id
  name         String
  time         String
  reward       String
  status       String                 @default("scheduled")
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @default(now()) @updatedAt
  participants GuildEventParticipant[]

  @@index([status, updatedAt])
}

model GuildEventParticipant {
  eventId  Int
  userId   String
  joinedAt DateTime   @default(now())
  event    GuildEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId, joinedAt])
}

model TicketRecord {
  channelId String   @id
  id        Int
  guildId   String?
  userId    String?
  category  String?
  reason    String?
  status    String   @default("open")
  claimedBy String?
  createdAt DateTime @default(now())
  closedAt  DateTime?
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status, updatedAt])
  @@index([guildId, status])
}

model WeaponStat {
  weapon          String   @id
  kills           Int      @default(0)
  longestDistance Float    @default(0)
  recordHolder    String?
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([kills])
  @@index([updatedAt])
}

model WelcomeClaim {
  userId    String   @id
  claimedAt DateTime @default(now())
}

model Punishment {
  id              Int      @id @default(autoincrement())
  userId          String
  type            String
  reason          String
  staffId         String
  durationMinutes Int?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model Giveaway {
  messageId    String          @id
  channelId    String
  guildId      String
  prize        String
  winnersCount Int             @default(1)
  endsAt       DateTime
  entrants     GiveawayEntrant[]

  @@index([guildId, endsAt])
}

model GiveawayEntrant {
  messageId String
  userId    String
  joinedAt  DateTime @default(now())
  giveaway  Giveaway @relation(fields: [messageId], references: [messageId], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId, joinedAt])
}

model TopPanelMessage {
  guildId   String
  panelType String
  channelId String
  messageId String
  updatedAt DateTime @default(now()) @updatedAt

  @@id([guildId, panelType])
  @@index([guildId, updatedAt])
}

model DeliveryAudit {
  id           String   @id
  createdAt    DateTime @default(now())
  tenantId     String?
  level        String
  action       String
  purchaseCode String?
  itemId       String?
  userId       String?
  steamId      String?
  attempt      Int?
  message      String
  metaJson     String?

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([level, createdAt])
  @@index([action, createdAt])
}

model AdminAuditPreset {
  id            String   @id
  name          String
  view          String   @default("wallet")
  visibility    String   @default("public")
  sharedRole    String?
  query         String?
  userId        String?
  actor         String?
  actorMode     String   @default("contains")
  reason        String?
  reference     String?
  referenceMode String   @default("contains")
  status        String?
  statusMode    String   @default("contains")
  dateFrom      String?
  dateTo        String?
  sortBy        String   @default("timestamp")
  sortOrder     String   @default("desc")
  windowMs      Int?
  pageSize      Int      @default(50)
  createdBy     String?
  createdByUser String?
  updatedBy     String?
  updatedByUser String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([updatedAt])
  @@index([name])
  @@index([visibility])
  @@index([sharedRole])
  @@index([createdByUser])
}

model AdminWebUser {
  username     String   @id
  passwordHash String   @map("password_hash")
  role         String   @default("mod")
  tenantId     String?  @map("tenant_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([role, isActive])
  @@index([tenantId, role])
  @@map("admin_web_users")
}

model RedeemCode {
  code    String   @id
  type    String
  amount  Int?
  itemId  String?
  usedBy  String?
  usedAt  DateTime?
}

model VipMembership {
  userId   String   @id
  planId   String
  expiresAt DateTime
}

model Bounty {
  id         Int     @id @default(autoincrement())
  targetName String
  amount     Int
  createdBy  String
  status     String  @default("active")
  claimedBy  String?
}

model KillFeedEvent {
  id            Int      @id @default(autoincrement())
  tenantId      String?
  serverId      String?
  killerName    String
  killerSteamId String?
  killerUserId  String?
  victimName    String
  victimSteamId String?
  victimUserId  String?
  weapon        String
  distance      Int?
  hitZone       String?
  sector        String?
  mapImageUrl   String?
  metadataJson  String?
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, serverId, occurredAt])
  @@index([killerUserId, occurredAt])
  @@index([victimUserId, occurredAt])
  @@map("kill_feed_events")
}

model PlatformRaidRequest {
  id             Int      @id @default(autoincrement())
  tenantId       String?  @map("tenant_id")
  requesterUserId String  @map("requester_user_id")
  requesterName  String   @map("requester_name")
  requestText    String   @map("request_text")
  preferredWindow String? @map("preferred_window")
  status         String   @default("pending")
  decisionNote   String?  @map("decision_note")
  reviewedBy     String?  @map("reviewed_by")
  reviewedAt     DateTime? @map("reviewed_at")
  serverId       String?  @map("server_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, requesterUserId, updatedAt])
  @@index([tenantId, serverId, updatedAt])
  @@map("platform_raid_requests")
}

model PlatformRaidWindow {
  id         Int      @id @default(autoincrement())
  tenantId   String?  @map("tenant_id")
  requestId  Int?     @map("request_id")
  title      String
  startsAt   DateTime @map("starts_at")
  endsAt     DateTime? @map("ends_at")
  status     String   @default("scheduled")
  notes      String?
  actor      String?
  serverId   String?  @map("server_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId, status, startsAt])
  @@index([tenantId, serverId, startsAt])
  @@index([requestId, startsAt])
  @@map("platform_raid_windows")
}

model PlatformRaidSummary {
  id        Int      @id @default(autoincrement())
  tenantId  String?  @map("tenant_id")
  requestId Int?     @map("request_id")
  windowId  Int?     @map("window_id")
  outcome   String
  notes     String?
  createdBy String?  @map("created_by")
  serverId  String?  @map("server_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([tenantId, serverId, createdAt])
  @@index([requestId, createdAt])
  @@index([windowId, createdAt])
  @@map("platform_raid_summaries")
}

model Stats {
  userId          String @id
  kills           Int    @default(0)
  deaths          Int    @default(0)
  playtimeMinutes Int    @default(0)
  squad           String?
}

model Link {
  steamId    String   @id
  userId     String
  inGameName String?
  linkedAt   DateTime @default(now())
}

model ScumStatus {
  id            Int      @id @default(1)
  onlinePlayers Int      @default(0)
  maxPlayers    Int      @default(90)
  pingMs        Int?
  uptimeMinutes Int      @default(0)
  lastUpdated   DateTime?
}

model BotConfig {
  id        Int      @id
  configJson String
  updatedAt DateTime @default(now()) @updatedAt
}

model DeliveryQueueJob {
  purchaseCode     String   @id
  tenantId         String?
  userId           String
  itemId           String
  itemName         String?
  iconUrl          String?
  gameItemId       String?
  quantity         Int      @default(1)
  deliveryItemsJson String?
  itemKind         String?
  guildId          String?
  attempts         Int      @default(0)
  nextAttemptAt    DateTime
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([nextAttemptAt])
  @@index([updatedAt])
}

model DeliveryDeadLetter {
  purchaseCode     String   @id
  tenantId         String?
  userId           String?
  itemId           String?
  itemName         String?
  guildId          String?
  attempts         Int      @default(0)
  reason           String
  lastError        String?
  deliveryItemsJson String?
  metaJson         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([createdAt])
  @@index([updatedAt])
}

model LuckyWheelState {
  userId      String   @id
  lastSpinAt  DateTime?
  totalSpins  Int      @default(0)
  historyJson String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([updatedAt])
}

model PartyChatMessage {
  id          String   @id
  partyKey    String   @map("party_key")
  userId      String   @map("user_id")
  displayName String   @map("display_name")
  message     String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([partyKey, createdAt])
  @@index([userId, createdAt])
  @@map("party_chat_messages")
}

model DailyRent {
  userKey   String   @map("user_key")
  date      String
  used      Boolean  @default(false)
  updatedAt DateTime @default(now()) @map("updated_at")

  @@id([userKey, date])
  @@index([date, updatedAt])
  @@map("daily_rent")
}

model RentalVehicle {
  orderId           String   @id @map("order_id")
  userKey           String   @map("user_key")
  guildId           String?  @map("guild_id")
  vehicleInstanceId String?  @map("vehicle_instance_id")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")
  destroyedAt       DateTime? @map("destroyed_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  attemptCount      Int      @default(0) @map("attempt_count")
  lastError         String?  @map("last_error")

  @@index([status])
  @@index([userKey])
  @@index([createdAt])
  @@map("rental_vehicles")
}

model PlatformTenant {
  id            String   @id
  slug          String   @unique
  name          String
  type          String   @default("direct")
  status        String   @default("active")
  locale        String   @default("th")
  ownerName     String?
  ownerEmail    String?
  parentTenantId String?
  metadataJson  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([status, updatedAt])
  @@index([type, updatedAt])
  @@index([parentTenantId])
}

model PlatformSubscription {
  id           String   @id
  tenantId     String
  planId       String
  billingCycle String   @default("monthly")
  status       String   @default("active")
  currency     String   @default("THB")
  amountCents  Int      @default(0)
  startedAt    DateTime @default(now())
  renewsAt     DateTime?
  canceledAt   DateTime?
  externalRef  String?
  metadataJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([status, renewsAt])
}

model PlatformLicense {
  id              String   @id
  tenantId        String
  licenseKey      String   @unique
  status          String   @default("active")
  seats           Int      @default(1)
  issuedAt        DateTime @default(now())
  expiresAt       DateTime?
  legalDocVersion String?
  legalAcceptedAt DateTime?
  metadataJson    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([status, expiresAt])
}

model PlatformApiKey {
  id         String   @id
  tenantId   String
  name       String
  keyPrefix  String
  keyHash    String
  scopesJson String
  status     String   @default("active")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([status, updatedAt])
  @@index([keyPrefix])
}

model PlatformWebhookEndpoint {
  id            String   @id
  tenantId      String
  name          String
  eventType     String
  targetUrl     String
  secretValue   String
  enabled       Boolean  @default(true)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([eventType, updatedAt])
  @@index([enabled, updatedAt])
}

model PlatformAgentRuntime {
  id               String   @id
  tenantId         String
  runtimeKey       String
  channel          String?
  version          String
  minRequiredVersion String?
  status           String   @default("online")
  lastSeenAt       DateTime @default(now())
  metaJson         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([tenantId, runtimeKey])
  @@index([tenantId, updatedAt])
  @@index([status, updatedAt])
}

model PlatformMarketplaceOffer {
  id         String   @id
  tenantId   String
  title      String
  kind       String   @default("service")
  priceCents Int      @default(0)
  currency   String   @default("THB")
  status     String   @default("active")
  locale     String   @default("th")
  metaJson   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([status, updatedAt])
}

model PlatformPreviewAccount {
  id                   String   @id
  email                String   @unique
  passwordHash         String
  displayName          String?
  communityName        String?
  locale               String   @default("en")
  packageId            String   @default("BOT_LOG_DELIVERY")
  accountState         String   @default("preview")
  verificationState    String   @default("registered")
  tenantId             String?
  subscriptionId       String?
  linkedIdentitiesJson String?
  lastLoginAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  @@index([accountState, updatedAt])
  @@index([tenantId, updatedAt])
  @@index([subscriptionId, updatedAt])
}

model PlatformUser {
  id           String   @id
  primaryEmail String?  @unique
  displayName  String?
  passwordHash String?
  locale       String   @default("en")
  status       String   @default("active")
  metadataJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([status, updatedAt])
  @@map("platform_users")
}

model PlatformUserIdentity {
  id             String   @id
  userId         String
  provider       String
  providerUserId String
  providerEmail  String?
  displayName    String?
  avatarUrl      String?
  verifiedAt     DateTime?
  linkedAt       DateTime @default(now())
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([provider, providerUserId])
  @@index([userId, linkedAt])
  @@index([provider, providerEmail])
  @@map("platform_user_identities")
}

model PlatformMembership {
  id             String   @id
  userId         String
  tenantId       String?
  membershipType String   @default("tenant")
  role           String   @default("member")
  status         String   @default("active")
  isPrimary      Boolean  @default(false)
  invitedAt      DateTime?
  acceptedAt     DateTime?
  revokedAt      DateTime?
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([userId, updatedAt])
  @@index([tenantId, role, updatedAt])
  @@index([status, updatedAt])
  @@map("platform_memberships")
}

model PlatformPlayerProfile {
  id                String   @id
  userId            String
  tenantId          String?
  discordUserId     String?
  steamId           String?
  inGameName        String?
  verificationState String   @default("unverified")
  linkedAt          DateTime?
  lastSeenAt        DateTime?
  metadataJson      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([userId, updatedAt])
  @@index([tenantId, steamId])
  @@index([tenantId, discordUserId])
  @@index([verificationState, updatedAt])
  @@map("platform_player_profiles")
}

model PlatformVerificationToken {
  id               String   @id
  userId           String?
  previewAccountId String?
  purpose          String   @default("email_verification")
  tokenType        String?
  tokenPrefix      String
  tokenHash        String
  email            String?
  target           String?
  expiresAt        DateTime
  consumedAt       DateTime?
  metadataJson     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([tokenType, tokenHash])
  @@unique([email, tokenHash])
  @@index([previewAccountId, expiresAt])
  @@index([userId, purpose, expiresAt])
  @@index([email, purpose, expiresAt])
  @@index([consumedAt, expiresAt])
  @@map("platform_verification_tokens")
}

model PlatformPasswordResetToken {
  id             String   @id
  userId         String?
  previewAccountId String?
  email          String
  tokenPrefix    String
  tokenHash      String
  expiresAt      DateTime
  consumedAt     DateTime?
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([email, tokenHash])
  @@index([userId, expiresAt])
  @@index([previewAccountId, expiresAt])
  @@index([consumedAt, expiresAt])
  @@map("platform_password_reset_tokens")
}

model PlatformBillingCustomer {
  id           String   @id
  tenantId     String   @unique
  userId       String?
  email        String?
  displayName  String?
  externalRef  String?
  status       String   @default("active")
  metadataJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([status, updatedAt])
  @@index([userId, updatedAt])
  @@map("platform_billing_customers")
}

model PlatformBillingInvoice {
  id             String   @id
  tenantId       String
  subscriptionId String?
  customerId     String?
  status         String   @default("draft")
  currency       String   @default("THB")
  amountCents    Int      @default(0)
  dueAt          DateTime?
  paidAt         DateTime?
  externalRef    String?
  metadataJson   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([tenantId, createdAt])
  @@index([subscriptionId, status, updatedAt])
  @@index([customerId, status, updatedAt])
  @@map("platform_billing_invoices")
}

model PlatformBillingPaymentAttempt {
  id           String   @id
  invoiceId    String?
  tenantId     String
  provider     String
  status       String   @default("pending")
  amountCents  Int      @default(0)
  currency     String   @default("THB")
  externalRef  String?
  errorCode    String?
  errorDetail  String?
  attemptedAt  DateTime @default(now())
  completedAt  DateTime?
  metadataJson String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([tenantId, attemptedAt])
  @@index([invoiceId, status, attemptedAt])
  @@index([provider, status, attemptedAt])
  @@map("platform_billing_payment_attempts")
}

model PlatformSubscriptionEvent {
  id             String   @id
  tenantId       String
  subscriptionId String
  eventType      String
  billingStatus  String?
  actor          String?
  payloadJson    String?
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([tenantId, occurredAt])
  @@index([subscriptionId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("platform_subscription_events")
}

model PlatformTenantConfig {
  tenantId         String   @id @map("tenant_id")
  configPatchJson  String?  @map("config_patch_json")
  portalEnvPatchJson String? @map("portal_env_patch_json")
  featureFlagsJson String?  @map("feature_flags_json")
  updatedBy        String?  @map("updated_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([updatedAt])
  @@map("platform_tenant_configs")
}

model PlatformServerConfigSnapshot {
  serverId     String   @id @map("server_id")
  tenantId     String   @map("tenant_id")
  runtimeKey   String?  @map("runtime_key")
  status       String   @default("ready")
  snapshotJson String   @map("snapshot_json")
  collectedAt  DateTime @default(now()) @map("collected_at")
  updatedBy    String?  @map("updated_by")
  lastJobId    String?  @map("last_job_id")
  lastError    String?  @map("last_error")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId, updatedAt])
  @@index([runtimeKey, updatedAt])
  @@map("platform_server_config_snapshots")
}

model PlatformServerConfigJob {
  id                 String   @id
  tenantId           String   @map("tenant_id")
  serverId           String   @map("server_id")
  jobType            String   @default("config_update") @map("job_type")
  applyMode          String   @default("save_only") @map("apply_mode")
  status             String   @default("queued")
  requestedBy        String?  @map("requested_by")
  requestedAt        DateTime @default(now()) @map("requested_at")
  claimedByRuntimeKey String? @map("claimed_by_runtime_key")
  claimedAt          DateTime? @map("claimed_at")
  completedAt        DateTime? @map("completed_at")
  changesJson        String?  @map("changes_json")
  resultJson         String?  @map("result_json")
  errorText          String?  @map("error_text")
  metaJson           String?  @map("meta_json")

  @@index([tenantId, serverId, requestedAt])
  @@index([status, requestedAt])
  @@map("platform_server_config_jobs")
}

model PlatformServerConfigBackup {
  id                String   @id
  tenantId          String   @map("tenant_id")
  serverId          String   @map("server_id")
  jobId             String?  @map("job_id")
  fileName          String   @map("file_name")
  backupPath        String?  @map("backup_path")
  changedBy         String?  @map("changed_by")
  changeSummaryJson String?  @map("change_summary_json")
  metaJson          String?  @map("meta_json")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([tenantId, serverId, createdAt])
  @@index([jobId, createdAt])
  @@map("platform_server_config_backups")
}

model PlatformRestartPlan {
  id            String   @id
  tenantId      String   @map("tenant_id")
  serverId      String   @map("server_id")
  guildId       String?  @map("guild_id")
  runtimeKey    String?  @map("runtime_key")
  status        String   @default("scheduled")
  restartMode   String   @default("delayed") @map("restart_mode")
  controlMode   String   @default("service") @map("control_mode")
  requestedBy   String?  @map("requested_by")
  scheduledFor  DateTime @map("scheduled_for")
  delaySeconds  Int      @default(0) @map("delay_seconds")
  reason        String?
  payloadJson   String?  @map("payload_json")
  healthStatus  String?  @map("health_status")
  healthVerifiedAt DateTime? @map("health_verified_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([tenantId, scheduledFor])
  @@index([serverId, scheduledFor])
  @@index([status, scheduledFor])
  @@map("platform_restart_plans")
}

model PlatformRestartAnnouncement {
  id              String   @id
  planId          String   @map("plan_id")
  tenantId        String   @map("tenant_id")
  serverId        String   @map("server_id")
  checkpointSeconds Int    @map("checkpoint_seconds")
  message         String
  channel         String?
  status          String   @default("pending")
  scheduledFor    DateTime @map("scheduled_for")
  sentAt          DateTime? @map("sent_at")
  metaJson        String?  @map("meta_json")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([planId, scheduledFor])
  @@index([status, scheduledFor])
  @@map("platform_restart_announcements")
}

model PlatformRestartExecution {
  id            String   @id
  planId        String   @map("plan_id")
  tenantId      String   @map("tenant_id")
  serverId      String   @map("server_id")
  runtimeKey    String?  @map("runtime_key")
  action        String   @default("restart")
  resultStatus  String   @default("pending") @map("result_status")
  startedAt     DateTime @default(now()) @map("started_at")
  completedAt   DateTime? @map("completed_at")
  exitCode      Int?     @map("exit_code")
  detail        String?
  metaJson      String?  @map("meta_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([planId, startedAt])
  @@index([tenantId, serverId, startedAt])
  @@map("platform_restart_executions")
}

model PlatformAdminNotification {
  id             String   @id
  type           String   @default("notice")
  source         String   @default("system")
  kind           String   @default("notice")
  severity       String   @default("info")
  title          String
  message        String
  entityKey      String?
  dataJson       String?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([createdAt])
  @@index([severity, createdAt])
  @@index([kind, createdAt])
  @@index([entityKey, createdAt])
  @@index([acknowledgedAt, createdAt])
}

model PlatformAdminSecurityEvent {
  id           String   @id
  occurredAt   DateTime @default(now())
  type         String   @default("security-event")
  severity     String   @default("info")
  actor        String?
  targetUser   String?
  role         String?
  authMethod   String?
  sessionId    String?
  ip           String?
  path         String?
  reason       String?
  detail       String?
  dataJson     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([occurredAt])
  @@index([severity, occurredAt])
  @@index([type, occurredAt])
  @@index([sessionId, occurredAt])
}

model PlatformAdminRequestLog {
  id         String   @id
  occurredAt DateTime @default(now())
  method     String   @default("GET")
  path       String
  routeGroup String   @default("unknown")
  statusCode Int      @default(0)
  statusClass String  @default("other")
  latencyMs  Int      @default(0)
  ok         Boolean  @default(false)
  authMode   String?
  user       String?
  role       String?
  tenantId   String?
  ip         String?
  origin     String?
  userAgent  String?
  source     String?
  note       String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@index([occurredAt])
  @@index([routeGroup, occurredAt])
  @@index([tenantId, occurredAt])
  @@index([statusCode, occurredAt])
}

model PlatformAdminRestoreState {
  id              String   @id
  status          String   @default("idle")
  active          Boolean  @default(false)
  maintenance     Boolean  @default(false)
  operationId     String?
  backup          String?
  confirmBackup   String?
  rollbackBackup  String?
  actor           String?
  role            String?
  note            String?
  startedAt       DateTime?
  endedAt         DateTime?
  lastCompletedAt DateTime?
  durationMs      Int?
  lastError       String?
  rollbackStatus  String   @default("none")
  rollbackError   String?
  countsJson      String?
  currentCountsJson String?
  diffJson        String?
  warningsJson    String?
  verificationJson String?
  previewToken    String?
  previewBackup   String?
  previewIssuedAt DateTime?
  previewExpiresAt DateTime?
  historyJson     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([updatedAt])
  @@index([status, updatedAt])
}

model PlatformAutomationState {
  id                               String   @id
  lastAutomationAt                 DateTime?
  lastForcedMonitoringAt           DateTime?
  lastRecoveryAtByKeyJson          String?
  recoveryWindowStartedAtByKeyJson String?
  recoveryAttemptsByKeyJson        String?
  lastRecoveryResultByKeyJson      String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @default(now()) @updatedAt

  @@index([updatedAt])
}

model PlatformOpsState {
  id                   String   @id
  lastMonitoringAt     DateTime?
  lastAutoBackupAt     DateTime?
  lastReconcileAt      DateTime?
  lastAlertAtByKeyJson String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  @@index([updatedAt])
}

model ControlPlaneServer {
  id           String   @id
  tenantId     String
  slug         String?
  name         String
  status       String   @default("active")
  locale       String   @default("th")
  guildId      String?
  metadataJson String?
  actor        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([tenantId, updatedAt])
  @@index([tenantId, guildId])
  @@index([tenantId, slug])
}

model ControlPlaneServerDiscordLink {
  id           String   @id
  tenantId     String
  serverId     String
  guildId      String
  status       String   @default("active")
  metadataJson String?
  actor        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([tenantId, guildId])
  @@index([tenantId, serverId, updatedAt])
}

model ControlPlaneAgent {
  id             String   @id
  tenantId       String
  serverId       String
  guildId        String?
  agentId        String
  runtimeKey     String
  displayName    String?
  role           String   @default("hybrid")
  scope          String   @default("sync_execute")
  channel        String?
  version        String?
  minimumVersion String?
  status         String   @default("active")
  baseUrl        String?
  hostname       String?
  metadataJson   String?
  actor          String?
  lastSeenAt     DateTime?
  lastSyncAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@unique([tenantId, serverId, agentId])
  @@index([tenantId, serverId, runtimeKey])
  @@index([status, updatedAt])
}

model ControlPlaneAgentTokenBinding {
  id         String   @id
  tenantId   String
  serverId   String
  guildId    String?
  agentId    String
  apiKeyId   String   @unique
  role       String   @default("hybrid")
  scope      String   @default("sync_execute")
